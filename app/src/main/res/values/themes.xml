<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ES" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2ABFBF</item>
        <item name="colorPrimaryVariant">#1E9E9E</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#2ABFBF</item>
        <item name="android:colorBackground">#EFF2F5</item>
    </style>

    <style name="Theme.ES" parent="Base.Theme.ES" />

    <style name="LabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">#AAAAAA</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FieldStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_field_normal</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">#2C2C2C</item>
        <item name="android:textColorHint">#C5C5C5</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center_vertical</item>
    </style>
</resources>