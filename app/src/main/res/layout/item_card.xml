<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ivCardBg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/defaultdebitcard" />

        <TextView
            android:id="@+id/tvCardNameDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/ivCardBg"
            android:layout_alignEnd="@id/ivCardBg"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="32dp"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="Card Name" />

        <TextView
            android:id="@+id/tvCardNumberDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/ivCardBg"
            android:layout_alignBottom="@id/ivCardBg"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="XXXX XXXX XXXX XXXX" />

        <TextView
            android:id="@+id/tvCardHolderDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/ivCardBg"
            android:layout_alignStart="@id/ivCardBg"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="44dp"
            android:text="CARD HOLDER"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvBalanceDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/ivCardBg"
            android:layout_alignEnd="@id/ivCardBg"
            android:layout_marginBottom="44dp"
            android:layout_marginEnd="32dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="₹ 0.00" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>
