<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Account"
        android:textColor="#1A1A2E"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etAccountName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_field_normal"
        android:hint="Account Name (e.g. HDFC Bank)"
        android:paddingStart="12dp"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etAccountType"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_field_normal"
        android:hint="Type (e.g. Savings, Credit)"
        android:paddingStart="12dp"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etAccountBalance"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_field_normal"
        android:hint="Initial Balance"
        android:inputType="numberDecimal"
        android:paddingStart="12dp"
        android:textSize="14sp" />

</LinearLayout>
