<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9F9"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow_black"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Reconciliation"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Initial State (Upload Container) -->
    <LinearLayout
        android:id="@+id/layoutInitial"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_receipt_long"
            app:tint="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Upload bank statement to begin"
            android:textColor="#999999"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUploadStatement"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Select PDF"
            android:textColor="@android:color/white"
            app:backgroundTint="#2ABFBF"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Result State (Hidden by default) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layoutResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#F5F9F9">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 0: Raw Extracted Text -->
            <LinearLayout
                android:id="@+id/debugSectionRaw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A888888"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[DEBUG] Section 0: Raw Extracted Text"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDebugRawSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/tvDebugRawText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#333333"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <!-- Section A: Transaction Section -->
            <LinearLayout
                android:id="@+id/debugSectionA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A000000"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[DEBUG] Section A: Transaction Section"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDebugSectionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#333333"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <!-- Section B: Transaction Blocks -->
            <LinearLayout
                android:id="@+id/debugSectionB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A0000FF"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[DEBUG] Section B: Transaction Blocks"
                    android:textColor="#000088"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDebugBlocks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#000088"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <!-- Section C: Formatted Chunks -->
            <LinearLayout
                android:id="@+id/debugSectionC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A880088"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[DEBUG] Section C: Formatted Chunks"
                    android:textColor="#880088"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDebugChunks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#880088"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <!-- Section D: AI Responses -->
            <LinearLayout
                android:id="@+id/debugSectionD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A008800"
                android:padding="8dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[DEBUG] Section D: AI Responses"
                    android:textColor="#005500"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDebugResponses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#005500"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/debugDivider"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Section D: Final Transactions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Final Transactions"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Processing Overlay State (Hidden by default) -->
    <FrameLayout
        android:id="@+id/overlayProcessing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="100dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="@android:color/white" />

            <TextView
                android:id="@+id/tvProcessingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Processing document..."
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
